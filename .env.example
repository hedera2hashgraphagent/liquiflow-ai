# OpenAI — required for /api/chat
OPENAI_API_KEY=sk-...

# WalletConnect Cloud — https://cloud.reown.com/
NEXT_PUBLIC_WALLETCONNECT_PROJECT_ID=your_project_id_here

# Server-side AP2 MPP submission via hederaService.executeAP2Payment()
# payerAccountId must match HEDERA_OPERATOR_ID. Browser payments use HashPack instead.
# Private key: DER hex (302e...) or raw ED25519 — PrivateKey.fromString() accepts both.
HEDERA_OPERATOR_ID=0.0.12345
HEDERA_OPERATOR_PRIVATE_KEY=302e...
